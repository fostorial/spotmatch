<%- include("partials/header") %>

<section class="account-header">
  <div>
    <p class="eyebrow"><a href="/admin">Admin</a> / Users</p>
    <h1><%= profileUser.username %></h1>
    <p class="account-email muted"><%= profileUser.email || 'No email address set' %></p>
  </div>
</section>

<article class="panel">
  <div class="panel-header">
    <h2>Decks</h2>
    <span class="muted"><%= decks.length %> total</span>
  </div>

  <% if (decks.length === 0) { %>
    <p>This user has not created any decks.</p>
  <% } else { %>
    <div class="deck-list">
      <% decks.forEach((deck) => { %>
        <article class="deck-item">
          <div>
            <h3><a href="/decks/<%= deck.id %>"><%= deck.title %></a></h3>
            <p><%= deck.version === 'junior' ? 'Junior' : 'Classic' %> deck preset</p>
            <p class="muted">
              <%= deck.total_cards %> cards, <%= deck.total_symbols %> symbols, <%= deck.symbols_per_card %> symbols per card
            </p>
          </div>
          <div class="deck-actions">
            <a class="button button-secondary" href="/decks/<%= deck.id %>">View</a>
          </div>
        </article>
      <% }) %>
    </div>
  <% } %>
</article>

<%- include("partials/footer") %>
