<%- include("partials/header") %>

<section class="narrow-panel">
  <h1>Forgot your password?</h1>

  <% if (sent) { %>
    <div class="alert alert-success">
      If an account exists for that email address you'll receive a reset link shortly.
      Check your spam folder if it doesn't arrive within a few minutes.
    </div>
    <p><a href="/login">Back to login</a></p>
  <% } else { %>
    <p>Enter the email address on your account and we'll send you a link to choose a new password.</p>
    <%- include("partials/errors") %>
    <form method="post" action="/forgot-password" class="stack-form">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>" />
      <label>
        Email address
        <input type="email" name="email" value="<%= form.email || '' %>" maxlength="254" autocomplete="email" required />
      </label>
      <button type="submit" class="button">Send reset link</button>
    </form>
    <p><a href="/login">Back to login</a></p>
  <% } %>
</section>

<%- include("partials/footer") %>
