NODE_ENV=development
PORT=3000
SESSION_SECRET=change-this-to-a-long-random-secret
APP_URL=http://localhost:3000

# IONOS SMTP — set SMTP_PASS to enable email sending.
# In development, reset links are printed to the console when SMTP_PASS is empty.
SMTP_HOST=smtp.ionos.co.uk
SMTP_PORT=587
SMTP_USER=noreply@spotmatch.fostorial.co.uk
SMTP_PASS=
